# Copy to .env and fill in. server.py auto-loads .env (existing env vars win).
# Everything degrades gracefully if a key is absent (template / no-enrichment).

# Claude — powers the investigation report AND the GenAI reverse-engineering.
# Without it, a deterministic template report is used (the app still works).
ANTHROPIC_API_KEY=

# Report model (fast). The deep reverse-engineering uses Opus by default.
# APK_LLM_MODEL=claude-haiku-4-5

# Threat intel + DYNAMIC sandbox runtime behavior (free keys):
#   VirusTotal:    https://www.virustotal.com  (file reputation + sandbox detonation)
#   MalwareBazaar: https://auth.abuse.ch        (family lookup + real-sample download)
VT_API_KEY=
MWB_API_KEY=

# Optional self-hosted live detonation (MobSF) — only if you run a MobSF server
# with a connected Android emulator:
# MOBSF_URL=http://127.0.0.1:8000
# MOBSF_API_KEY=

# Server bind (Colab/cloud: APK_HOST=0.0.0.0)
# APK_HOST=127.0.0.1
# APK_PORT=8800
